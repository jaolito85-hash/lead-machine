# ══════════════════════════════════════════════════════════════
# LEAD MACHINE — VARIAVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha com suas chaves
# ══════════════════════════════════════════════════════════════

# ─── PAPERCLIP (Control Plane) ───
PAPERCLIP_PORT=3100
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
# DATABASE_URL=postgresql://user:pass@localhost:5432/paperclip  # opcional, PGlite por padrao

# Runners locais
# Para o piloto de apostas, deixe o runner generico desligado e o runner de apostas ligado.
START_GENERIC_RUNNER=0
START_APOSTAS_RUNNER=1

# ─── APIFY (scrapers multi-plataforma — PRINCIPAL) ───
# Crie conta gratis: https://console.apify.com/sign-up
# Pegue o token em: Settings > Integrations > API Token
# Free tier: $5/mes de creditos (~30 runs)
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXX

# ─── SERPAPI (Google Search + Google Maps) ───
# Crie conta gratis: https://serpapi.com/users/sign_up
# Free tier: 100 buscas/mes
SERPAPI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── FIRECRAWL (scraping de websites para extrair dados) ───
# Crie conta gratis: https://firecrawl.dev
# Free tier: 500 paginas/mes
FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXX

# ─── GOOGLE PLACES API (Google Maps — $200/mes gratis) ───
# Console: https://console.cloud.google.com
# Ative: Places API, Maps JavaScript API
# Crie API Key em: APIs & Services > Credentials
# $200/mes de credito gratis = ~11.000 buscas de negocio
GOOGLE_PLACES_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── APOLLO.IO (enriquecimento de leads — MELHOR FREE TIER) ───
# Crie conta gratis: https://app.apollo.io/#/login
# Free tier: 10.000 emails/mes (!) + API access
# Pegue a key em: Settings > Integrations > API Keys
APOLLO_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── HUNTER.IO (encontrar emails por dominio) ───
# Crie conta gratis: https://hunter.io/users/sign_up
# Free tier: 25 buscas de dominio + 50 verificacoes/mes
HUNTER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── REDDIT (PRAW — API gratuita e generosa) ───
# Crie app em: https://www.reddit.com/prefs/apps
# Tipo: "script" | Redirect: http://localhost:8080
# Free: 60 requests/minuto, sem limite mensal
REDDIT_CLIENT_ID=XXXXXXXXXXXXXX
REDDIT_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXX
REDDIT_USER_AGENT=lead_machine/1.0

# ─── TWITTER/X (API oficial — so paga funciona pra busca) ───
# Developer portal: https://developer.twitter.com
# Free tier: so posta tweets (INUTIL pra lead gen)
# Basic tier ($100/mes): 10.000 leituras + busca
# Se nao quiser pagar, use Apify Twitter scraper
TWITTER_BEARER_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# TWITTER_API_KEY=
# TWITTER_API_SECRET=

# ─── INSTAGRAM (Instaloader — sem API key, usa login) ───
# Conta burner recomendada (risco de ban na conta principal)
# Sem login: scraping limitado de hashtags publicas
# Com login: mais requests antes de bloqueio
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ─── PROXIES (rotacao de IP — evita bloqueios) ───
# Opcoes: BrightData, Oxylabs, SmartProxy, IPRoyal
# Residenciais sao melhores que datacenter
# Formato: http://usuario:senha@host:porta
PROXY_URL=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ─── PHANTOMBUSTER (LinkedIn/Instagram automation — opcional) ───
# Free: 14 dias trial, 2h de execucao
# https://phantombuster.com
PHANTOMBUSTER_API_KEY=

# ─── SNOV.IO (email finding — alternativa ao Hunter) ───
# Free: 50 creditos/mes
# https://snov.io
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ─── TELEGRAM (notificacao de lead quente) ───
# 1. No Telegram, procure @BotFather e rode /newbot. Ele retorna um token.
# 2. Procure seu novo bot e mande /start.
# 3. Abra https://api.telegram.org/bot<TOKEN>/getUpdates e copie "chat":{"id":...}.
# Teste: python agents/telegram_notifier.py --test
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ══════════════════════════════════════════════════════════════
# NICHO: APOSTAS ESPORTIVAS
# Empresa isolada — agents-apostas/ + leads-apostas/
# Estas vars sobrescrevem o comportamento padrão APENAS para os
# scripts dentro de agents-apostas/
# ══════════════════════════════════════════════════════════════

# ─── Identificação do cliente da casa de apostas ───
# Nome slug da casa de apostas destino (aparece como clienteDestino no lead)
# Exemplos: betano, bet365, vaidebet, atletabet, ...
APOSTAS_CLIENTE=seubet
APOSTAS_BRAND=SeuBet
APOSTAS_OPERATOR=H2 LICENSED LTDA
APOSTAS_OFFICIAL_DOMAIN=https://www.seu.bet.br/
APOSTAS_AFFILIATE_URL=https://www.seu.bet.br/affiliates/?btag=2709913
APOSTAS_UTM_CAMPAIGN=seubet_br_pilot
APOSTAS_OPERATOR_AUTH=SPA/MF 253/2025
APOSTAS_PILOT_BUDGET_USD=5000
APOSTAS_MVP_MAX_LEADS=300

# ─── Nicho específico (padrão: apostas_esportivas) ───
# Outros: futebol_apostas, cassino_online, esports_betting
APOSTAS_NICHO=apostas_esportivas

# ─── Perfis Instagram extras para scraping ───
# Separados por vírgula. Deixar vazio para usar os perfis padrão
# (bet365brasil_, betanobrasil, vaidebet_, etc. definidos em base_apostas.py)
# Exemplo: minhacasa_oficial,tipsterparceiro
APOSTAS_INSTAGRAM_PROFILES=

# ─── Score mínimo para notificar no Telegram ───
# Leads acima deste score disparam alerta Telegram imediato
# Padrão: 80 (= leads "quentes")
APOSTAS_SCORE_MIN_NOTIF=80

# ─── Número máximo de leads por ciclo ───
APOSTAS_LIMIT_POR_AGENTE=50

# ─── Telegram separado para apostas (opcional) ───
# Se quiser receber alertas de leads de apostas num canal diferente
# do canal principal (TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID)
# Deixar vazio para usar o mesmo bot/canal configurado acima
APOSTAS_TELEGRAM_BOT_TOKEN=
APOSTAS_TELEGRAM_CHAT_ID=
